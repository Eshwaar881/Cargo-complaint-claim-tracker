# ============================================================
# CARGO COMPLAINT & CLAIM TRACKER — Backend Environment Variables
# ============================================================
# Copy this file to `.env` and fill in REAL values there.
# NEVER commit `.env` to git. NEVER paste real keys into chat.
#
# Rotate any key that has ever been shared outside a secrets
# manager or your local .env file before using it here.
# ============================================================

PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Gemini (AI triage summaries / recommendations) ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace_with_your_gemini_key
GEMINI_MODEL=gemini-2.5-flash

# --- SendGrid (confirmation / reminder / follow-up emails) ---
# Get a key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=replace_with_your_sendgrid_key
SENDGRID_FROM_EMAIL=ops@yourcargocompany.com
SENDGRID_FROM_NAME="Cargo Ops Desk"

# --- OpenRouteService (ETA / distance estimation for delay severity) ---
# Get a key at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=replace_with_your_ors_key

# --- Feature flags / fallbacks ---
# If true, AI calls are skipped and rule-based logic is used instead
# (also auto-enabled automatically if GEMINI_API_KEY call fails)
DISABLE_AI=false

# --- SLA thresholds (hours) used by the rule-based reminder engine ---
SLA_HOURS_CRITICAL=4
SLA_HOURS_HIGH=12
SLA_HOURS_MEDIUM=24
SLA_HOURS_LOW=48
