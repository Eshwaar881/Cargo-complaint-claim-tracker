# ─── Firebase Web App Configuration ────────────────────────────────────────────
# 1. Go to https://console.firebase.google.com
# 2. Create (or open) your project
# 3. Project Settings → General → Your apps → Web app → SDK setup
# 4. Copy each value below from the firebaseConfig object

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# ─── Steps to enable auth providers ────────────────────────────────────────────
# Firebase Console → Authentication → Sign-in method:
#   1. Enable "Email/Password"   (for manager psm@nxtwave.in)
#   2. Enable "Google"           (for customers)
#
# Then manually create the manager account:
#   Authentication → Users → Add user
#     Email:    psm@nxtwave.in
#     Password: nxtwave123!
